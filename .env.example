# ============================================================
# .env — Environment variables for llm-robot-cs424
# Copy this file to .env and fill in your values.
# No API keys needed! Llama 3 runs fully locally via Ollama.
# ============================================================

# Ollama model to use for task planning (optional)
# Recommended : llama3.2-vision  (multimodal — sees camera snapshots)
# Text-only   : llama3           (faster, no image support)
OLLAMA_MODEL=llama3.2-vision

# Ollama server URL (optional — only change if you moved the server)
OLLAMA_HOST=http://localhost:11434
